@model Veltis.Workspace.Web.Models.Admin.UserEditViewModel
@{
    ViewData["Title"] = "Editar usuario";
}

@await Html.PartialAsync("_Breadcrumb", new[] { "Admin", "Usuarios", "Editar" })
<h1 class="mb-6 text-3xl font-semibold tracking-tight">Editar usuario</h1>

<form method="post" class="max-w-2xl space-y-5 rounded border border-zinc-200 bg-white p-6 dark:border-zinc-800 dark:bg-zinc-900">
    <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>
    <div>
        <label asp-for="DisplayName" class="text-sm font-medium">Nome</label>
        <input asp-for="DisplayName" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-950" />
        <span asp-validation-for="DisplayName" class="text-sm text-red-600"></span>
    </div>
    <div>
        <label asp-for="Email" class="text-sm font-medium">E-mail</label>
        <input asp-for="Email" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-950" />
        <span asp-validation-for="Email" class="text-sm text-red-600"></span>
    </div>
    <div>
        <label asp-for="ProfessionId" class="text-sm font-medium">Profissao</label>
        <select asp-for="ProfessionId" asp-items="ViewBag.Professions" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-950">
            <option value="">Selecione</option>
        </select>
        <span asp-validation-for="ProfessionId" class="text-sm text-red-600"></span>
    </div>
    <label class="flex items-center gap-2 text-sm">
        <input asp-for="IsActive" class="h-4 w-4 rounded border-zinc-300" />
        Ativo
    </label>
    <div class="flex gap-3">
        <button type="submit" class="rounded bg-zinc-950 px-4 py-2 text-sm font-semibold text-white dark:bg-white dark:text-zinc-950">Salvar</button>
        <a asp-action="Index" class="rounded border border-zinc-300 px-4 py-2 text-sm font-semibold dark:border-zinc-700">Cancelar</a>
    </div>
</form>

<form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-4">
    <button type="submit" class="rounded border border-red-300 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50 dark:border-red-900 dark:text-red-300 dark:hover:bg-red-950">Excluir</button>
</form>

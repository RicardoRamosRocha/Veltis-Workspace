@model Veltis.Workspace.Web.Models.Admin.RoleFormViewModel
@{
    ViewData["Title"] = "Editar role";
}

@await Html.PartialAsync("_Breadcrumb", new[] { "Admin", "Roles", "Editar" })
<h1 class="mb-6 text-3xl font-semibold tracking-tight">Editar role</h1>
@await Html.PartialAsync("_RoleForm", Model)

@if (!Model.IsSystemRole)
{
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mt-4">
        <button type="submit" class="rounded border border-red-300 px-4 py-2 text-sm font-semibold text-red-700 hover:bg-red-50 dark:border-red-900 dark:text-red-300 dark:hover:bg-red-950">Excluir</button>
    </form>
}

@{
    ViewData["Title"] = "Inicio";
}

<section class="max-w-4xl">
    <p class="text-sm font-semibold uppercase tracking-wide text-teal-700 dark:text-teal-300">Sprint 0</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-zinc-950 dark:text-white sm:text-5xl">Veltis Workspace</h1>
    <p class="mt-5 max-w-2xl text-lg leading-8 text-zinc-600 dark:text-zinc-300">
        Plataforma SaaS de produtividade profissional baseada em inteligencia artificial, preparada para evoluir com um motor reutilizavel de agentes.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <span class="rounded bg-emerald-600 px-4 py-2 text-sm font-semibold text-white">Autenticado</span>
        }
        else
        {
            <a class="rounded bg-zinc-950 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-800 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200" asp-controller="Account" asp-action="Login">Entrar</a>
            <a class="rounded border border-zinc-300 px-4 py-2 text-sm font-semibold hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-900" asp-controller="Account" asp-action="Register">Criar conta</a>
        }
    </div>
</section>

<section class="mt-12 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <div class="rounded border border-zinc-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-900">
        <h2 class="font-semibold">Clean Architecture</h2>
        <p class="mt-2 text-sm leading-6 text-zinc-600 dark:text-zinc-300">Camadas separadas para dominio, aplicacao, infraestrutura e interface web.</p>
    </div>
    <div class="rounded border border-zinc-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-900">
        <h2 class="font-semibold">PostgreSQL</h2>
        <p class="mt-2 text-sm leading-6 text-zinc-600 dark:text-zinc-300">Persistencia configurada com Entity Framework Core e Npgsql.</p>
    </div>
    <div class="rounded border border-zinc-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-900">
        <h2 class="font-semibold">Identity</h2>
        <p class="mt-2 text-sm leading-6 text-zinc-600 dark:text-zinc-300">Usuarios e papeis preparados para permissoes futuras.</p>
    </div>
    <div class="rounded border border-zinc-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-900">
        <h2 class="font-semibold">Docker</h2>
        <p class="mt-2 text-sm leading-6 text-zinc-600 dark:text-zinc-300">Ambiente local com aplicacao web, banco e volumes persistentes.</p>
    </div>
</section>

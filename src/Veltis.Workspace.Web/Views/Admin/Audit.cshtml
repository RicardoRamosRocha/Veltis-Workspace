@model Veltis.Workspace.Web.Models.Admin.AdminAuditListViewModel
@{
    ViewData["Title"] = "Auditoria";
}

@await Html.PartialAsync("_Breadcrumb", new[] { "Admin", "Auditoria" })

<div class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight">Auditoria</h1>
    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">Consulta somente leitura dos registros de auditoria existentes.</p>
</div>

<form method="get" class="mb-6 grid gap-3 rounded border border-zinc-200 bg-white p-4 dark:border-zinc-800 dark:bg-zinc-900 md:grid-cols-5">
    <input name="userId" value="@Model.UserId" placeholder="Usuário" class="vw-input" />
    <input name="action" value="@Model.Action" placeholder="Ação" class="vw-input" />
    <input name="entityName" value="@Model.EntityName" placeholder="Entidade" class="vw-input" />
    <input name="date" value="@(Model.Date?.ToString("yyyy-MM-dd"))" type="date" class="vw-input" />
    <button class="vw-button" type="submit">Filtrar</button>
</form>

@{
    string[] headers = ["Data", "Usuário", "Ação", "Entidade", "Id"];
    IEnumerable<string[]> rows = Model.Rows.Select(row => new[]
    {
        row.OccurredAt.ToString("dd/MM/yyyy HH:mm"),
        row.UserId?.ToString() ?? "-",
        row.Action,
        row.EntityName,
        row.EntityId ?? "-"
    });
}

@await Html.PartialAsync("_DataTable", (headers, rows))

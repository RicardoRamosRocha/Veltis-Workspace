@model Veltis.Workspace.Web.Models.Admin.AdminResourceListViewModel
@{
    ViewData["Title"] = Model.Title;
}

@await Html.PartialAsync("_Breadcrumb", new[] { "Admin", Model.Title })

<div class="mb-6 flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
    <div>
        <h1 class="text-3xl font-semibold tracking-tight">@Model.Title</h1>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">Busca, paginação e edição administrativa.</p>
    </div>
    <a class="vw-button" href="/admin/@Model.Resource/create">Novo</a>
</div>

<form method="get" class="mb-4 flex gap-2">
    <input name="search" value="@Model.Search" class="vw-input max-w-md" placeholder="Buscar..." />
    <button type="submit" class="vw-button">Buscar</button>
</form>

@if (!Model.Rows.Any())
{
    <partial name="DesignSystem/_EmptyState" model="@("Nenhum registro encontrado.")" />
}
else
{
    <div class="overflow-hidden rounded border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-zinc-200 text-sm dark:divide-zinc-800">
                <thead class="bg-zinc-50 text-left dark:bg-zinc-950">
                    <tr>
                        @foreach (string header in Model.Headers)
                        {
                            <th class="px-4 py-3 font-semibold">@header</th>
                        }
                        <th class="px-4 py-3 font-semibold">Ações</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-zinc-200 dark:divide-zinc-800">
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            @foreach (string cell in row.Cells)
                            {
                                <td class="px-4 py-3 text-zinc-600 dark:text-zinc-300">@cell</td>
                            }
                            <td class="px-4 py-3">
                                <div class="flex flex-wrap items-center gap-3">
                                    <a class="font-semibold text-teal-700 dark:text-teal-300" href="/admin/@Model.Resource/details/@row.Id">Detalhes</a>
                                    <a class="font-semibold text-teal-700 dark:text-teal-300" href="/admin/@Model.Resource/edit/@row.Id">Editar</a>
                                    @if (Model.Resource == "form-definitions")
                                    {
                                        <a class="font-semibold text-teal-700 dark:text-teal-300" href="/admin/@Model.Resource/preview/@row.Id">Preview</a>
                                    }
                                    @if (row.CanToggle)
                                    {
                                        <form method="post" action="/admin/@Model.Resource/toggle/@row.Id">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="font-semibold text-zinc-700 dark:text-zinc-200">Ativar/Inativar</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<nav class="mt-4 flex items-center justify-between text-sm">
    <span>Página @Model.Page de @Model.TotalPages</span>
    <div class="flex gap-2">
        @if (Model.Page > 1)
        {
            <a class="rounded border border-zinc-300 px-3 py-2 dark:border-zinc-700" href="/admin/@Model.Resource?search=@Model.Search&page=@(Model.Page - 1)">Anterior</a>
        }
        @if (Model.Page < Model.TotalPages)
        {
            <a class="rounded border border-zinc-300 px-3 py-2 dark:border-zinc-700" href="/admin/@Model.Resource?search=@Model.Search&page=@(Model.Page + 1)">Próxima</a>
        }
    </div>
</nav>

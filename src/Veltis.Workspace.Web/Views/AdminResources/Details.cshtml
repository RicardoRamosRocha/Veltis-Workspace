@model Veltis.Workspace.Web.Models.Admin.AdminResourceFormViewModel
@{
    ViewData["Title"] = $"Detalhes - {Model.Title}";
}

@await Html.PartialAsync("_Breadcrumb", new[] { "Admin", Model.Title, "Detalhes" })

<div class="mb-6 flex items-center justify-between">
    <h1 class="text-3xl font-semibold tracking-tight">@ViewData["Title"]</h1>
    <a class="vw-button" href="/admin/@Model.Resource/edit/@Model.Id">Editar</a>
</div>

<dl class="grid gap-4 rounded border border-zinc-200 bg-white p-6 dark:border-zinc-800 dark:bg-zinc-900 md:grid-cols-2">
    @foreach (var field in Model.Fields)
    {
        string value = Model.Values.TryGetValue(field.Spec.Name, out string? fieldValue) ? fieldValue ?? "-" : "-";
        <div>
            <dt class="text-xs font-semibold uppercase tracking-wide text-zinc-500">@field.Spec.Label</dt>
            <dd class="mt-1 whitespace-pre-wrap text-sm text-zinc-800 dark:text-zinc-100">@value</dd>
        </div>
    }
</dl>

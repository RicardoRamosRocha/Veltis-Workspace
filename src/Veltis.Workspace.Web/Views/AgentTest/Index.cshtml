@model Veltis.Workspace.Application.Agents.Execution.AgentExecutionResult?
@{
    ViewData["Title"] = "Teste do Motor de Agentes";
}

@await Html.PartialAsync("_Breadcrumb", new[] { "Agentes", "Teste" })

<div class="mx-auto max-w-5xl py-8">
    <div class="mb-6">
        <h1 class="text-3xl font-bold">Teste do Framework Universal de Agentes</h1>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">Executa o pipeline com OpenAI quando houver API Key configurada; sem chave, usa fallback simulado.</p>
    </div>

    <form method="post" class="space-y-4 rounded border border-zinc-200 bg-white p-6 dark:border-zinc-800 dark:bg-zinc-900">
        <div>
            <label class="text-sm font-medium">Título</label>
            <input name="title" class="mt-2 w-full rounded border border-zinc-300 bg-white p-2 text-sm dark:border-zinc-700 dark:bg-zinc-950" />
        </div>

        <div>
            <label class="text-sm font-medium">Descrição</label>
            <textarea rows="6" name="description" class="mt-2 w-full rounded border border-zinc-300 bg-white p-2 text-sm dark:border-zinc-700 dark:bg-zinc-950"></textarea>
        </div>

        <button class="vw-button" type="submit">Executar Pipeline</button>
    </form>

    @if (Model is not null)
    {
        <section class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            @await Html.PartialAsync("_MetricCard", ("Provider", Model.Provider, "Utilizado"))
            @await Html.PartialAsync("_MetricCard", ("Modelo", Model.Model, "Configuração ativa"))
            @await Html.PartialAsync("_MetricCard", ("Tokens entrada", Model.InputTokens.ToString(), "Prompt"))
            @await Html.PartialAsync("_MetricCard", ("Tokens saída", Model.OutputTokens.ToString(), "Resposta"))
        </section>

        <section class="mt-4 rounded border border-zinc-200 bg-white p-4 text-sm dark:border-zinc-800 dark:bg-zinc-900">
            <strong>Custo estimado:</strong> @Model.EstimatedCost.ToString("0.######")
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.FallbackMessage))
        {
            <div class="mt-4 rounded border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900 dark:border-amber-900 dark:bg-amber-950 dark:text-amber-100">
                @Model.FallbackMessage
            </div>
        }

        @if (!Model.Success && !string.IsNullOrWhiteSpace(Model.Error))
        {
            <div class="mt-4 rounded border border-red-200 bg-red-50 p-4 text-sm text-red-900 dark:border-red-900 dark:bg-red-950 dark:text-red-100">
                @Model.Error
            </div>
        }

        <h2 class="mt-8 text-xl font-semibold">Prompt Gerado</h2>
        <pre class="mt-3 overflow-x-auto rounded bg-zinc-100 p-4 text-sm dark:bg-zinc-900">@Model.Prompt</pre>

        <h2 class="mt-6 text-xl font-semibold">Resposta</h2>
        <pre class="mt-3 whitespace-pre-wrap rounded bg-zinc-100 p-4 text-sm dark:bg-zinc-900">@Model.Response</pre>
    }
</div>

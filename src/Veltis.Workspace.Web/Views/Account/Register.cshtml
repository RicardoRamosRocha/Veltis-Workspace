@model RegisterViewModel
@{
    ViewData["Title"] = "Criar conta";
}

<section class="mx-auto max-w-md">
    <h1 class="text-3xl font-semibold tracking-tight">Criar conta</h1>
    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">Comece com uma conta base para validar a autenticacao.</p>

    <form asp-action="Register" method="post" class="mt-8 space-y-5">
        <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>
        <div>
            <label asp-for="DisplayName" class="text-sm font-medium">Nome</label>
            <input asp-for="DisplayName" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm outline-none focus:border-teal-600 dark:border-zinc-700 dark:bg-zinc-900" autocomplete="name" />
            <span asp-validation-for="DisplayName" class="mt-1 block text-sm text-red-600"></span>
        </div>
        <div>
            <label asp-for="Email" class="text-sm font-medium">E-mail</label>
            <input asp-for="Email" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm outline-none focus:border-teal-600 dark:border-zinc-700 dark:bg-zinc-900" autocomplete="email" />
            <span asp-validation-for="Email" class="mt-1 block text-sm text-red-600"></span>
        </div>
        <div>
            <label asp-for="ProfessionId" class="text-sm font-medium">Profissao</label>
            <select asp-for="ProfessionId" asp-items="ViewBag.Professions" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm outline-none focus:border-teal-600 dark:border-zinc-700 dark:bg-zinc-900">
                <option value="">Selecione</option>
            </select>
            <span asp-validation-for="ProfessionId" class="mt-1 block text-sm text-red-600"></span>
        </div>
        <div>
            <label asp-for="Password" class="text-sm font-medium">Senha</label>
            <input asp-for="Password" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm outline-none focus:border-teal-600 dark:border-zinc-700 dark:bg-zinc-900" autocomplete="new-password" />
            <span asp-validation-for="Password" class="mt-1 block text-sm text-red-600"></span>
        </div>
        <div>
            <label asp-for="ConfirmPassword" class="text-sm font-medium">Confirmar senha</label>
            <input asp-for="ConfirmPassword" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm outline-none focus:border-teal-600 dark:border-zinc-700 dark:bg-zinc-900" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="mt-1 block text-sm text-red-600"></span>
        </div>
        <button type="submit" class="w-full rounded bg-zinc-950 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-800 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200">Criar conta</button>
    </form>
</section>

@model LoginViewModel
@{
    ViewData["Title"] = "Entrar";
}

<section class="mx-auto max-w-md">
    <h1 class="text-3xl font-semibold tracking-tight">Entrar</h1>
    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-300">Acesse sua conta do Veltis Workspace.</p>

    <form asp-action="Login" method="post" class="mt-8 space-y-5">
        <input asp-for="ReturnUrl" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>
        <div>
            <label asp-for="Email" class="text-sm font-medium">E-mail</label>
            <input asp-for="Email" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm outline-none focus:border-teal-600 dark:border-zinc-700 dark:bg-zinc-900" autocomplete="email" />
            <span asp-validation-for="Email" class="mt-1 block text-sm text-red-600"></span>
        </div>
        <div>
            <label asp-for="Password" class="text-sm font-medium">Senha</label>
            <input asp-for="Password" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm outline-none focus:border-teal-600 dark:border-zinc-700 dark:bg-zinc-900" autocomplete="current-password" />
            <span asp-validation-for="Password" class="mt-1 block text-sm text-red-600"></span>
        </div>
        <label class="flex items-center gap-2 text-sm">
            <input asp-for="RememberMe" class="h-4 w-4 rounded border-zinc-300" />
            Manter conectado
        </label>
        <button type="submit" class="w-full rounded bg-zinc-950 px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-800 dark:bg-white dark:text-zinc-950 dark:hover:bg-zinc-200">Entrar</button>
        <p class="text-center text-sm text-zinc-600 dark:text-zinc-300">
            Ainda nao tem conta?
            <a asp-action="Register" class="font-semibold text-teal-700 dark:text-teal-300">Criar conta</a>
        </p>
    </form>
</section>

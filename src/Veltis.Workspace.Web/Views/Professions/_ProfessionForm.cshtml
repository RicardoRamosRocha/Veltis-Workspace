@model Veltis.Workspace.Web.Models.Admin.ProfessionFormViewModel

<form method="post" class="max-w-2xl space-y-5 rounded border border-zinc-200 bg-white p-6 dark:border-zinc-800 dark:bg-zinc-900">
    <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>
    <div>
        <label asp-for="Name" class="text-sm font-medium">Nome</label>
        <input asp-for="Name" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-950" />
        <span asp-validation-for="Name" class="text-sm text-red-600"></span>
    </div>
    <div>
        <label asp-for="Description" class="text-sm font-medium">Descricao</label>
        <textarea asp-for="Description" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-950"></textarea>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
        <div>
            <label asp-for="Icon" class="text-sm font-medium">Icone</label>
            <input asp-for="Icon" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-950" />
        </div>
        <div>
            <label asp-for="Color" class="text-sm font-medium">Cor</label>
            <input asp-for="Color" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-950" />
        </div>
        <div>
            <label asp-for="Slug" class="text-sm font-medium">Slug</label>
            <input asp-for="Slug" class="mt-2 w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-950" />
            <span asp-validation-for="Slug" class="text-sm text-red-600"></span>
        </div>
    </div>
    <label class="flex items-center gap-2 text-sm">
        <input asp-for="Active" class="h-4 w-4 rounded border-zinc-300" />
        Ativa
    </label>
    <div class="flex gap-3">
        <button type="submit" class="rounded bg-zinc-950 px-4 py-2 text-sm font-semibold text-white dark:bg-white dark:text-zinc-950">Salvar</button>
        <a asp-action="Index" class="rounded border border-zinc-300 px-4 py-2 text-sm font-semibold dark:border-zinc-700">Cancelar</a>
    </div>
</form>

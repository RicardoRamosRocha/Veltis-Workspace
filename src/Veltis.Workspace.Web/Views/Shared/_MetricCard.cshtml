@model (string Title, string Value, string Subtitle)

<article class="rounded border border-zinc-200 bg-white p-5 dark:border-zinc-800 dark:bg-zinc-900">
    <p class="text-sm text-zinc-500">@Model.Title</p>
    <strong class="mt-3 block text-3xl font-semibold">@Model.Value</strong>
    <span class="mt-2 block text-xs uppercase tracking-wide text-zinc-400">@Model.Subtitle</span>
</article>

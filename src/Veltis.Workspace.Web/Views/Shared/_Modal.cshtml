@model (string Id, string Title, string Body)

<div id="@Model.Id" class="hidden fixed inset-0 z-50 items-center justify-center bg-zinc-950/60 p-4" data-modal>
    <div class="w-full max-w-lg rounded border border-zinc-200 bg-white p-6 shadow-xl dark:border-zinc-800 dark:bg-zinc-900">
        <div class="flex items-center justify-between gap-4">
            <h2 class="text-lg font-semibold">@Model.Title</h2>
            <button type="button" class="rounded px-2 py-1 text-sm hover:bg-zinc-100 dark:hover:bg-zinc-800" data-modal-close="@Model.Id">Fechar</button>
        </div>
        <div class="mt-4 text-sm text-zinc-600 dark:text-zinc-300">@Html.Raw(Model.Body)</div>
    </div>
</div>
